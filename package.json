{
  "name": "stb-deploy-tool",
  "version": "1.0.0",
  "description": "Smart TV/STB deployment CLI tool for Lightning (lng) projects",
  "keywords": [
    "stb",
    "smart-tv",
    "lightning",
    "lng",
    "deploy",
    "cli"
  ],
  "author": "pushpeet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pushpeet/stb-deploy-tool.git"
  },
  "homepage": "https://github.com/pushpeet/stb-deploy-tool#readme",
  "bugs": {
    "url": "https://github.com/pushpeet/stb-deploy-tool/issues"
  },
  "bin": {
    "stb": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "build:watch": "tsc --watch",
    "dev": "ts-node src/cli.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "execa": "^5.1.1",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0",
    "ora": "^5.4.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
